APP_ENV=development
SECRET_KEY=dev-secret-key

# 阿里云百炼 / DashScope
DASHSCOPE_API_KEY=replace-with-your-dashscope-api-key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ASR: 百炼 Qwen3-ASR-Flash，OpenAI 兼容 chat/completions 接口
ASR_MODEL=qwen3-asr-flash-2026-02-10
ASR_ENABLE_ITN=false

# Agent LLM: 同样走百炼 OpenAI 兼容接口
AGENT_MODEL=qwen-plus
AGENT_TEMPERATURE=0

LOG_LEVEL=INFO
LOG_FILE_PATH=instance/ai_calender.log
